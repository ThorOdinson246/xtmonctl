pkgname=xtmonctl
pkgver=0.1.1
pkgrel=1
pkgdesc="External monitor brightness control for Linux via ddcutil"
arch=("x86_64")
url="https://github.com/ThorOdinson246/xmonctl-rs"
license=("MIT")
depends=("ddcutil")
makedepends=("cargo")
source=("${pkgname}-${pkgver}.tar.gz::https://github.com/ThorOdinson246/xmonctl-rs/archive/refs/tags/v${pkgver}.tar.gz")
sha256sums=("SKIP")

build() {
  cd "${srcdir}/xmonctl-rs-${pkgver}"
  cargo build --release --locked
}

package() {
  cd "${srcdir}/xmonctl-rs-${pkgver}"
  install -Dm755 "target/release/xtmonctl" "${pkgdir}/usr/bin/xtmonctl"
  install -Dm644 "README.md" "${pkgdir}/usr/share/doc/xtmonctl/README.md"
}
